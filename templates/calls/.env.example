# Recall.ai — bot joins Zoom/Teams/Meet calls and returns transcripts
# RECALL_AI_API_KEY=
# RECALL_WEBHOOK_SECRET=          # REQUIRED in prod when Recall is enabled — webhooks fail-closed without it

# Zoom OAuth — required for Zoom call recording integration
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_REDIRECT_URI=https://your-app.example.com/api/oauth/zoom/callback
# ZOOM_WEBHOOK_SECRET=            # REQUIRED in prod when Zoom is enabled — webhooks fail-closed without it

# Deepgram — webhook-based transcription (alternative to Recall.ai)
# DEEPGRAM_WEBHOOK_SECRET=        # REQUIRED in prod when Deepgram is enabled — webhooks fail-closed without it

# OAuth state signing — required if you use Zoom OAuth
# Falls back to BETTER_AUTH_SECRET if unset; setting it explicitly is recommended
# Generate via: openssl rand -hex 32
# OAUTH_STATE_SECRET=

# App URL — used in invite emails and webhook callback construction
# PUBLIC_URL=https://your-app.example.com

# Local-dev-only opt-out: accept webhooks without their signing secret.
# DO NOT set this in production — it disables signature verification.
# AGENT_NATIVE_ALLOW_UNVERIFIED_WEBHOOKS=1
