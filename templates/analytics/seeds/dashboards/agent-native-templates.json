{
  "name": "Agent Native Templates",
  "description": "Template engagement and per-app activity. Source: Amplitude.",
  "filters": [
    {
      "id": "days",
      "type": "select",
      "label": "Period",
      "default": "30",
      "options": [
        { "value": "7", "label": "Last 7 days" },
        { "value": "30", "label": "Last 30 days" },
        { "value": "90", "label": "Last 90 days" }
      ]
    }
  ],
  "panels": [
    {
      "id": "total-template-clicks",
      "title": "Template Clicks",
      "chartType": "metric",
      "source": "amplitude",
      "width": 1,
      "sql": "{\"event\":\"click template\",\"days\":{{days}}}",
      "config": {
        "yKey": "count",
        "yFormatter": "number",
        "description": "Last {{days}} days"
      }
    },
    {
      "id": "total-demo-clicks",
      "title": "Demo Clicks",
      "chartType": "metric",
      "source": "amplitude",
      "width": 1,
      "sql": "{\"event\":\"click try demo\",\"days\":{{days}}}",
      "config": {
        "yKey": "count",
        "yFormatter": "number",
        "description": "Last {{days}} days"
      }
    },
    {
      "id": "total-cli-copies",
      "title": "CLI Copies",
      "chartType": "metric",
      "source": "amplitude",
      "width": 1,
      "sql": "{\"event\":\"copy cli command\",\"days\":{{days}}}",
      "config": {
        "yKey": "count",
        "yFormatter": "number",
        "description": "Last {{days}} days"
      }
    },
    {
      "id": "template-interest-over-time",
      "title": "Template Interest Over Time",
      "chartType": "area",
      "source": "amplitude",
      "width": 2,
      "sql": "{\"event\":\"click template\",\"days\":{{days}}}",
      "config": {
        "xKey": "date",
        "yKey": "count",
        "color": "var(--brand-blue)"
      }
    },
    {
      "id": "clicks-by-template",
      "title": "Clicks by Template",
      "chartType": "bar",
      "source": "amplitude",
      "width": 1,
      "sql": "{\"event\":\"click template\",\"groupBy\":\"template\",\"days\":{{days}}}",
      "config": {
        "xKey": "template",
        "yKey": "count",
        "color": "var(--brand-blue)"
      }
    },
    {
      "id": "demo-clicks-by-template",
      "title": "Try-Demo Clicks by Template",
      "chartType": "bar",
      "source": "amplitude",
      "width": 1,
      "sql": "{\"event\":\"click try demo\",\"groupBy\":\"template\",\"days\":{{days}}}",
      "config": {
        "xKey": "template",
        "yKey": "count",
        "color": "var(--brand-teal)"
      }
    },
    {
      "id": "cli-copies-by-template",
      "title": "CLI Copies by Template",
      "chartType": "bar",
      "source": "amplitude",
      "width": 1,
      "sql": "{\"event\":\"copy cli command\",\"groupBy\":\"template\",\"days\":{{days}}}",
      "config": {
        "xKey": "template",
        "yKey": "count",
        "color": "#06b6d4"
      }
    },
    {
      "id": "cli-copies-over-time",
      "title": "CLI Copies Over Time",
      "chartType": "area",
      "source": "amplitude",
      "width": 2,
      "sql": "{\"event\":\"copy cli command\",\"days\":{{days}}}",
      "config": {
        "xKey": "date",
        "yKey": "count",
        "color": "#06b6d4"
      }
    },
    {
      "id": "sessions-by-app",
      "title": "Sessions by Agent-Native App",
      "chartType": "bar",
      "source": "amplitude",
      "width": 2,
      "sql": "{\"event\":\"session status\",\"groupBy\":\"app\",\"days\":{{days}}}",
      "config": {
        "xKey": "app",
        "yKey": "count",
        "color": "#10b981",
        "description": "Per-template-site session activity (mail, calendar, slides, ...). Each tab fires session status once."
      }
    },
    {
      "id": "signed-in-vs-anon",
      "title": "Signed-In vs Anonymous Sessions",
      "chartType": "bar",
      "source": "amplitude",
      "width": 1,
      "sql": "{\"event\":\"session status\",\"groupBy\":\"signed_in\",\"days\":{{days}}}",
      "config": {
        "xKey": "signed_in",
        "yKey": "count",
        "color": "#f59e0b",
        "description": "true = signed in, false = anonymous. Best proxy for total signups per period (still includes returning users)."
      }
    },
    {
      "id": "sessions-over-time",
      "title": "Sessions Over Time",
      "chartType": "area",
      "source": "amplitude",
      "width": 1,
      "sql": "{\"event\":\"session status\",\"days\":{{days}}}",
      "config": {
        "xKey": "date",
        "yKey": "count",
        "color": "#10b981"
      }
    }
  ]
}
