# GymOS Demo Sprint — local-only env vars (this file is committed, the
# real .env.local is gitignored). Copy to .env.local and fill in.
#
# Existing template-level secrets (Google OAuth, Better-auth, Neon) live in
# .env.example. Vars below are GymOS-specific additions for Phase D2 / D1-03.

# Demo-mode gate — REQUIRED for /api/m/* and the member-picker to function.
# requireDemoMember refuses requests when this is anything other than "true"
# AND NODE_ENV is not "production". Set to "true" locally; never set in prod.
DEMO_MODE=true

# Anthropic — agent surface in plan D2-06.
# Source: https://console.anthropic.com/settings/keys → Create Key
# (no spend cap needed for demo; ~$0.50 per 100 agent turns).
ANTHROPIC_API_KEY=sk-ant-...

# Expo / mobile-app: the URL the phone (running Expo Go) uses to reach the
# Vite SSR dev server. For LAN: http://<laptop-LAN-ip>:8081 — for tunnel:
# the public URL printed by `npx expo start --tunnel`. Set in
# packages/mobile-app/.env (NOT this file — Expo reads its own .env).
# EXPO_PUBLIC_API_BASE=http://192.168.x.x:8081

# WhatsApp — plan D2-02 (inbound webhook receiver + outbound from staff inbox).
# Source for all four: Meta App dashboard → WhatsApp → API Setup
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=gymos-demo-verify
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
