# Server port (production)
PORT=3000

# Builder-managed image generation is enabled by default.
# Set this to false only to force the manual Gemini fallback.
BUILDER_IMAGE_GENERATION_ENABLED=true

# Gemini is the manual fallback when Builder-managed image generation is unavailable.
GEMINI_API_KEY=

# S3-compatible object storage for originals, thumbnails, and exports.
IMAGES_STORAGE_BUCKET=
IMAGES_STORAGE_REGION=auto
IMAGES_STORAGE_ENDPOINT=
IMAGES_STORAGE_PUBLIC_BASE_URL=
IMAGES_STORAGE_ACCESS_KEY_ID=
IMAGES_STORAGE_SECRET_ACCESS_KEY=

# Custom health check message
PING_MESSAGE=pong
