{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "preview-install": {
      "distribution": "internal",
      "env": {
        "AGENT_NATIVE_MOBILE_DISABLE_REMOTE_PUSH": "1",
        "EXPO_PUBLIC_API_BASE": "https://gym-class-os.vercel.app"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
