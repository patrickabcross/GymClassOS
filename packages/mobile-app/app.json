{
  "expo": {
    "name": "Hustle",
    "slug": "hustle",
    "owner": "patrickalexanderross",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "agentnative",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.airunstudio.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.airunstudio.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-notifications",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "disableRemotePush": false,
      "eas": {
        "projectId": "fbcb9995-eada-4fca-8a34-498cf46f4021"
      }
    }
  }
}
