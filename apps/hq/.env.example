# ===========================================================================
# apps/hq — Environment Variables
# ===========================================================================
# Copy this file to .env (or .env.local for local dev) and fill in real values.
# NEVER commit a file with real secrets.
#
# HQ DATABASE — CRITICAL:
#   HQ must connect to its OWN dedicated Neon project (e.g. gymos-hq).
#   This is NEVER a studio Neon. Each studio has its own Neon project that
#   HQ provisions on behalf of the studio (BD2). HQ never holds studio Neon
#   connection strings — it stores only Neon project IDs.
#
#   Provision the HQ Neon project:
#     Option A: Neon Console → New Project → name it "gymos-hq"
#     Option B: neon_mcp create_project (if Neon MCP is available)
#   Then paste the POOLED connection string into DATABASE_URL and the
#   UNPOOLED (direct, no -pooler suffix) string into DATABASE_URL_UNPOOLED.
# ===========================================================================

# POOLED connection string (PgBouncer) — used by apps/hq (Vercel, stateless).
# Source: HQ Neon project (gymos-hq) → Connection Details → Pooled mode.
# NEVER a studio Neon. NEVER commit a real value.
DATABASE_URL=

# UNPOOLED (direct) connection string — used by services/hq-worker (Fly, long-lived).
# Source: HQ Neon project (gymos-hq) → Connection Details → Direct connection.
# NEVER a studio Neon. NEVER commit a real value.
DATABASE_URL_UNPOOLED=

# ---------------------------------------------------------------------------
# Better-auth (HQ super-admin auth — separate from every studio's auth)
# ---------------------------------------------------------------------------

# Secret key for Better-auth session signing.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Canonical public URL for the HQ app (used by Better-auth for callback URLs).
# Local dev example: http://localhost:3001
# Production: https://hq.gymclassos.com (or your Vercel deployment URL)
BETTER_AUTH_URL=

# ---------------------------------------------------------------------------
# Anthropic (Claude — HQ Brain + Dispatcher)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional: HQ WABA credentials (BD3 HQD — not required in BD1)
# ---------------------------------------------------------------------------
# HQ_WHATSAPP_PHONE_NUMBER_ID=
# HQ_WHATSAPP_ACCESS_TOKEN=
