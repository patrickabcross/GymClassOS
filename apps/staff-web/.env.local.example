# GymClassOS staff-web local-dev secrets — NEVER COMMIT (gitignored).
# Copy to apps/staff-web/.env.local and fill in values.
# Mirrors what templates/mail/.env.local provided during D0-D2 demo sprint.

# --- Neon Postgres (gymos-demo project) ---
# Pooled URL works for serverless / staff-web. Workers (P1b-04/05) use UNPOOLED.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# --- Better-auth (staff sessions) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8081

# --- Background jobs (D2 in-app agent scheduler etc.) ---
RUN_BACKGROUND_JOBS=1

# --- Anthropic (in-app agent + future inbox agent) ---
ANTHROPIC_API_KEY=

# --- Demo mode flag (D2 mobile-app demo auth) ---
DEMO_MODE=true

# --- WhatsApp (demo — staff number; webhook still in templates/mail until P1b-09 cutover) ---
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- Stripe (deferred to P1b/P0 — customer's restricted key) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Hosting preset (set to "vercel" for Vercel deploy, "netlify" for Netlify) ---
# NITRO_PRESET=vercel
