# ─── Single-tenant deploy mode (REQUIRED on Vercel) ──────────────────────────
# GymClassOS deploys ONE Vercel project per customer (single-tenant code,
# multi-tenant deploy at the infrastructure layer per CLAUDE.md tenancy rule).
# Upstream agent-native assumes multi-tenant SaaS, so by default it refuses to
# fall back to deploy-level env vars (like ANTHROPIC_API_KEY) for authenticated
# requests in production — that would cross-bill tenants on a shared deploy.
# With one tenant per deploy that hazard does not exist; flip this flag on so
# the framework reads ANTHROPIC_API_KEY (and STRIPE_SECRET_KEY etc.) from env.
#
# REQUIRED on every Vercel project for GymClassOS. Without it, the AgentSidebar
# shows the "Connect Builder.io" empty-state even with ANTHROPIC_API_KEY set,
# and the in-app Settings → API Keys save endpoint returns 403.
AGENT_NATIVE_SINGLE_TENANT=true

# ─── Agent (AI Assistant) ────────────────────────────────────────────────────
# ANTHROPIC_API_KEY — REQUIRED for the right-rail Chat agent. Without it, the
# framework's empty-state shows a "Connect Builder.io" prompt; we suppress
# that branding on /gymos/* via GymosBuilderCardSuppressor as defence in depth,
# but the proper fix is to set this env var on the deployment.
#
# Get a key at https://console.anthropic.com/settings/keys (any key with
# "Claude Sonnet" access is fine). Set in Vercel project env vars + redeploy.
# NOTE: Requires AGENT_NATIVE_SINGLE_TENANT=true (above) for the framework to
# actually read it for authenticated requests in production.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Auth allowlist (P1b.1-02) ───────────────────────────────────────────────
# CUSTOMER_ALLOWED_EMAILS — comma-separated emails allowed to sign in to /gymos.
# Empty or unset = dev fallback (no allowlist enforcement). Pilot-only gate,
# replaced by org-based ACL in P1a.
CUSTOMER_ALLOWED_EMAILS=
