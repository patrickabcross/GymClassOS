# ─── Agent (AI Assistant) ────────────────────────────────────────────────────
# ANTHROPIC_API_KEY — REQUIRED for the right-rail Chat agent. Without it, the
# framework's empty-state shows a "Connect Builder.io" prompt; we suppress
# that branding on /gymos/* via GymosBuilderCardSuppressor as defence in depth,
# but the proper fix is to set this env var on the deployment.
#
# Get a key at https://console.anthropic.com/settings/keys (any key with
# "Claude Sonnet" access is fine). Set in Vercel project env vars + redeploy.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Auth allowlist (P1b.1-02) ───────────────────────────────────────────────
# CUSTOMER_ALLOWED_EMAILS — comma-separated emails allowed to sign in to /gymos.
# Empty or unset = dev fallback (no allowlist enforcement). Pilot-only gate,
# replaced by org-based ACL in P1a.
CUSTOMER_ALLOWED_EMAILS=
