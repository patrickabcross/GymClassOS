# services/hq-worker — environment variables
#
# ============================================================
# PII BOUNDARY (HARD — DO NOT VIOLATE)
# hq-worker MUST NOT hold any studio credential or studio
# connection string. The PII-up boundary (HQ-FND-06 / D-12)
# requires that no studio Neon DSN, WHATSAPP_*, STRIPE_*,
# or PGCRYPTO_* keys appear in this file or in the Fly app
# secrets for gymos-hq-worker.
# ============================================================

# ---------------------------------------------------------------
# HQ Neon (REQUIRED)
# Use the UNPOOLED connection string (no -pooler in the hostname).
# pg-boss requires LISTEN/NOTIFY + advisory locks — the pooler
# connection will be rejected at startup (PITFALL #1).
#
# Set via: fly secrets set DATABASE_URL_UNPOOLED=<value> -a gymos-hq-worker
# Source:  HQ Neon project → Connection Details → "Direct" (not pooled)
# ---------------------------------------------------------------
DATABASE_URL_UNPOOLED=postgres://user:password@<hq-neon-host>.neon.tech/neondb

# ---------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------
PORT=3003
NODE_ENV=production
LOG_LEVEL=info
GIT_SHA=dev

# ---------------------------------------------------------------
# BD2 PROV (operator-provided, live runs only)
#
# These are OPTIONAL — the worker starts without them and unit tests
# use mock adapters. Set them in Fly secrets before running a live
# provisioning saga against real Neon / Vercel / Fly.
#
# IMPORTANT: FLY_API_TOKEN must be an org-scoped token created via:
#   fly tokens create org -n gymos-provisioner -o <org> -x 999999h
# Deploy tokens CANNOT set secrets; the provisioning saga uses
# `flyctl secrets set` via execa and requires org-level scope.
#
# Set via Fly secrets (NOT in this file — they contain API keys):
#   fly secrets set NEON_API_KEY=<value>          -a gymos-hq-worker
#   fly secrets set VERCEL_BEARER_TOKEN=<value>   -a gymos-hq-worker
#   fly secrets set VERCEL_TEAM_ID=<value>        -a gymos-hq-worker
#   fly secrets set FLY_API_TOKEN=<value>         -a gymos-hq-worker  # org-scoped
#   fly secrets set FLY_ORG_SLUG=<value>          -a gymos-hq-worker
#   fly secrets set GYMOS_WORKER_IMAGE=<value>    -a gymos-hq-worker
# ---------------------------------------------------------------
# NEON_API_KEY=               # Neon Console → Account Settings → API Keys
# VERCEL_BEARER_TOKEN=        # Vercel Dashboard → Settings → Tokens
# VERCEL_TEAM_ID=             # Vercel Dashboard → Team Settings → General
# FLY_API_TOKEN=              # fly tokens create org -n gymos-provisioner -o <org> (org-scoped)
# FLY_ORG_SLUG=               # fly orgs list
# GYMOS_WORKER_IMAGE=         # registry.fly.io/<image>:latest built by CI
