# services/worker/.env.example
#
# Copy to .env and fill in values for local development.
# Production values are set as Fly secrets — never commit .env.

# ── Database (REQUIRED) ─────────────────────────────────────────────────────
# pg-boss requires an UNPOOLED URL (LISTEN/NOTIFY + advisory locks).
# Must NOT include -pooler in the hostname.
DATABASE_URL_UNPOOLED=postgresql://user:password@host/db

# ── WhatsApp / MYÜTIK (REQUIRED) ────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
MYUTIK_API_KEY=
MYUTIK_PHONE_NUMBER_ID=

# ── Stripe (REQUIRED) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...

# ── pgcrypto master key (REQUIRED) ──────────────────────────────────────────
PGCRYPTO_MASTER_KEY=

# ── Shared encryption key (OPTIONAL) ────────────────────────────────────────
# Must match the same key used by staff-web BETTER_AUTH_SECRET or
# SECRETS_ENCRYPTION_KEY. Allows reading encrypted app_secrets from the DB.
SECRETS_ENCRYPTION_KEY=
BETTER_AUTH_SECRET=

# ── BD2-04: HQ Telemetry push (OPTIONAL) ────────────────────────────────────
# Set by the provisioning saga at Steps 4, 5, and 7 (BD2-05/06).
# When absent the telemetry-push cron handler logs a warning and skips;
# the worker boots cleanly — unconfigured studios are safe to deploy.
#
# HQ_INGEST_URL    — HTTPS URL of the HQ telemetry ingest endpoint.
#                    Example: https://hq.gymclassos.com/api/telemetry
# STUDIO_TELEMETRY_TOKEN — per-studio bearer token (plaintext).
#                    HQ stores only the sha256 hash; the studio holds the
#                    plaintext here. Generated by provisioning Step 7.
# STUDIO_ID        — opaque studio slug (e.g. "my-gym").
#                    Set during provisioning; used as the snapshot studioId.
# STUDIO_TIMEZONE  — IANA timezone string (e.g. "Europe/London").
#                    Informational for now; used in future localised reports.
HQ_INGEST_URL=
STUDIO_TELEMETRY_TOKEN=
STUDIO_ID=
STUDIO_TIMEZONE=

# ── Runtime ──────────────────────────────────────────────────────────────────
PORT=3002
GIT_SHA=dev
NODE_ENV=development
LOG_LEVEL=info
